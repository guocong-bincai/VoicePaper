# VoicePaper Caddy 配置文件
# 生产环境使用

# 主站配置 - voicepaper.online 和 voicepaper.top
voicepaper.online, voicepaper.top {
    # 自动HTTPS（Caddy会自动申请Let's Encrypt证书）
    
    # 日志配置
    log {
        output file /var/log/caddy/voicepaper.log
        format json
    }

    # API反向代理 - 后端服务
    handle /api/* {
        reverse_proxy localhost:8080 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # 前端静态文件服务
    handle {
        # 设置根目录（假设前端构建产物在这里）
        root * /var/www/voicepaper/frontend/dist
        
        # 开启文件服务
        file_server
        
        # SPA路由支持 - 所有路由都返回index.html
        try_files {path} /index.html
        
        # 设置静态资源缓存
        @static {
            path *.js *.css *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2 *.ttf *.eot
        }
        header @static Cache-Control "public, max-age=31536000, immutable"
    }

    # CORS配置（如果需要）
    header {
        # 安全头
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        X-XSS-Protection "1; mode=block"
        
        # 移除Server头（隐藏服务器信息）
        -Server
    }

    # 压缩
    encode gzip zstd
}

# www重定向（可选）
www.voicepaper.online {
    redir https://voicepaper.online{uri} permanent
}

www.voicepaper.top {
    redir https://voicepaper.top{uri} permanent
}

