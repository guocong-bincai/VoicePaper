# VoicePaper 项目配置文件示例
# 复制此文件为 config.yaml 并填入你的配置信息
# cp config.yaml.example config.yaml

# MiniMax API 配置
minimax:
  api_key: "your-minimax-api-key-here"
  base_url: "https://api.minimaxi.com/v1/t2a_async_v2"
  query_url: "https://api.minimaxi.com/v1/query/t2a_async_query_v2?task_id=%s"
  retrieve_url: "https://api.minimaxi.com/v1/files/retrieve?file_id=%s"

# 语音合成配置
tts:
  model: "speech-02-hd"
  voice_id: "Chinese (Mandarin)_Warm_Bestie"
  speed: 0.8
  volume: 1.0
  pitch: 0
  audio_sample_rate: 32000
  bitrate: 128000
  format: "mp3"
  channel: 1

# 文件存储配置
storage:
  type: "local"  # 'local' | 'oss' - 存储类型
  output_dir: "./data"  # 本地存储目录（type为local时使用）
  temp_dir: "./temp"   # 临时目录
  # OSS配置（type为oss时使用）
  oss:
    # Endpoint说明：
    # - 公网Endpoint：oss-cn-chengdu.aliyuncs.com（会产生流量费用）
    # - 内网Endpoint：oss-cn-chengdu-internal.aliyuncs.com（内网流量免费，仅限同地域ECS访问）
    # 如果后端部署在阿里云ECS上，建议使用内网Endpoint以节省流量费用
    endpoint: "oss-cn-chengdu.aliyuncs.com"  # OSS Endpoint（公网）或 oss-cn-chengdu-internal.aliyuncs.com（内网）
    access_key_id: "your-access-key-id"      # AccessKey ID（建议使用环境变量）
    access_key_secret: "your-access-key-secret"  # AccessKey Secret（建议使用环境变量）
    bucket: "voicepaper"                      # Bucket名称
    region: "cn-chengdu"                     # 区域
    base_url: ""                             # 自定义域名（可选），如 https://cdn.example.com
    use_https: true                          # 是否使用HTTPS

# 网络配置
network:
  timeout: 30  # 秒
  retry_count: 3

# 日志配置
logging:
  level: "info"
  file: "./logs/app.log"
  max_size: 10  # MB
  max_age: 7     # 天
  max_backups: 5

# 数据库配置
database:
  host: "your-database-host"
  port: 3306
  database: "your-database-name"
  username: "your-database-username"
  password: "your-database-password"
  charset: "utf8mb4"
  parse_time: true
  loc: "Local"
  max_idle_conns: 10
  max_open_conns: 100
  conn_max_lifetime: 3600  # 秒

# 服务配置
service:
  port: "8080"
  debug: false
  frontend_url: "http://localhost:5173"  # 前端地址

# 认证配置
auth:
  # JWT配置
  jwt:
    secret: "voicepaper-secret-key-change-in-production"  # 生产环境必须修改为强随机字符串
    expiration: 168  # 过期时间（小时），默认7天
  
  # 会话配置
  session:
    secret: "voicepaper-session-secret-change-in-production"  # 生产环境必须修改
    expiration: 168  # 过期时间（小时），默认7天
  
  # 邮箱验证码配置（SMTP）
  email:
    smtp_host: "smtp.qq.com"  # SMTP服务器地址
    smtp_port: 587  # SMTP端口
    smtp_user: "your_email@qq.com"  # SMTP用户名（邮箱地址）
    smtp_password: "your_email_auth_code"  # SMTP密码（邮箱授权码，不是登录密码）
    from_name: "VoicePaper"  # 发件人名称
    from_email: "your_email@qq.com"  # 发件人邮箱
  
  # OAuth配置
  oauth:
    # GitHub OAuth
    github:
      client_id: "your_github_client_id"
      client_secret: "your_github_client_secret"
      redirect_uri: "http://localhost:8080/api/v1/auth/github/callback"
    
    # Google OAuth
    google:
      client_id: "your_google_client_id"
      client_secret: "your_google_client_secret"
      redirect_uri: "http://localhost:8080/api/v1/auth/google/callback"


# Redis 配置
redis:
  host: "127.0.0.1"
  port: 6379
  password: ""
  db: 0
